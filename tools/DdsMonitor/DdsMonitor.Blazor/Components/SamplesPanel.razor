    private async Task FocusGrid()
    {
        await _gridRef.FocusAsync();
    }

    private async Task OnGridKeyDown(KeyboardEventArgs args)
    {
        if (!TryGetTotalCount(out var totalCount))
        {
            return;
        }

        var currentIndex = _selectedIndex >= 0 ? _selectedIndex : 0;
        var nextIndex = currentIndex;
        var handled = true;

        switch (args.Key)
        {
            case "ArrowDown":
                nextIndex = currentIndex + 1;
                break;
            case "ArrowUp":
                nextIndex = currentIndex - 1;
                break;
            case "PageDown":
                nextIndex = currentIndex + _lastRequestCount;
                break;
            case "PageUp":
                nextIndex = currentIndex - _lastRequestCount;
                break;
            case "Home":
                nextIndex = 0;
                break;
            case "End":
                nextIndex = totalCount - 1;
                break;
            case "Enter":
                if (_selectedSample != null)
                {
                    OpenDetail(_selectedSample);
                }

                return;
            default:
                handled = false;
                break;
        }

        if (!handled)
        {
            return;
        }

        nextIndex = Math.Clamp(nextIndex, 0, totalCount - 1);
        if (TrySelectByIndex(nextIndex))
        {
            await InvokeAsync(StateHasChanged);
            await Task.Delay(50);
            await EnsureSelectionVisibleAsync(nextIndex);
        }
    }

    private bool TrySelectByIndex(int index)
    {
        if (FixedSamples != null)
        {
            EnsureFixedView();
            if (index < 0 || index >= _viewCache.Count)
            {
                return false;
            }

            SelectSample(new IndexedSample(index, _viewCache[index]), false);
            return true;
        }

        var total = _sampleView!.CurrentFilteredCount;
        if (index < 0 || index >= total)
        {
            return false;
        }

        var s = _sampleView.GetVirtualView(index, 1);
        if (s.IsEmpty)
        {
            return false;
        }

        SelectSample(new IndexedSample(index, s.Span[0]), false);
        return true;
    }

    private bool TryGetTotalCount(out int totalCount)
    {
        if (FixedSamples != null)
        {
            EnsureFixedView();
            totalCount = _viewCache.Count;
            return totalCount > 0;
        }

        totalCount = _sampleView!.CurrentFilteredCount;
        return totalCount > 0;
    }

    private async Task EnsureSelectionVisibleAsync(int index)
    {
        await JSRuntime.InvokeVoidAsync("ddsMonitor.ensureRowVisible", _gridRef, index, RowHeight);
        await Task.Delay(1);
        await JSRuntime.InvokeVoidAsync("ddsMonitor.ensureSelectedRowVisible", _gridRef);
    }

    private RenderFragment RenderHeader(string label, FieldMetadata? field) => @<text>
        <button type="button" class="@GetHeaderClass(field)" @onclick="() => ToggleSort(field)">@label@GetSortIndicator(field)</button>
    </text>;

    private string GetHeaderClass(FieldMetadata? field)
    {
        var isSorted = field != null && ReferenceEquals(field, _sortField);
        return isSorted ? "samples-panel__header-btn is-sorted" : "samples-panel__header-btn";
    }

    private string GetSortIndicator(FieldMetadata? field)
    {
        if (field == null || !ReferenceEquals(field, _sortField))
        {
            return string.Empty;
        }

        return _sortDirection == SortDirection.Ascending ? " ^" : " v";
    }

    private void ToggleSort(FieldMetadata? field)
    {
        if (field == null)
        {
            return;
        }

        if (ReferenceEquals(field, _sortField))
        {
            _sortDirection = _sortDirection == SortDirection.Ascending
                ? SortDirection.Descending
                : SortDirection.Ascending;
        }
        else
        {
            _sortField = field;
            _sortDirection = SortDirection.Ascending;
        }

        _viewDirty = true; // For replay mode.
        _sampleView?.SetSortSpec(_sortField, _sortDirection); // For live mode.
        _ = _virtualizeRef?.RefreshDataAsync();

        if (_trackMode && _selectedIndex >= 0)
        {
            _ = InvokeAsync(async () =>
            {
                await Task.Delay(50);
                await EnsureSelectionVisibleAsync(_selectedIndex);
            });
        }

        StateHasChanged();
    }

    private string GetGridStyle()
    {
        if (_layoutColumns.Count == 0)
        {
            return string.Empty;
        }

        var parts = _layoutColumns
            .Select(column => FormattableString.Invariant($"{GetColumnWeight(column.Key):0.###}fr"));

        return FormattableString.Invariant($"grid-template-columns:{string.Join(" ", parts)};");
    }

    private double GetColumnWeight(string key)
    {
        if (_columnWeights.TryGetValue(key, out var weight))
        {
            return weight;
        }

        return 1.0;
    }

    private async Task BeginColumnResize(string columnKey, MouseEventArgs args)
    {
        var index = _layoutColumns.FindIndex(column =>
            string.Equals(column.Key, columnKey, StringComparison.Ordinal));
        if (index < 0 || index >= _layoutColumns.Count - 1)
        {
            return;
        }

        var size = await JSRuntime.InvokeAsync<ElementSize?>("ddsMonitor.getElementSize", _gridRef);
        _resizeGridWidth = size?.Width > 0 ? size.Width : 1;

        _isColumnResizing = true;
        _resizeColumnIndex = index;
        _resizeStartX = args.ClientX;
        _resizeStartLeftWeight = GetColumnWeight(_layoutColumns[index].Key);
        _resizeStartRightWeight = GetColumnWeight(_layoutColumns[index + 1].Key);
    }

    private void HandleColumnResize(MouseEventArgs args)
    {
        if (!_isColumnResizing || _resizeColumnIndex < 0)
        {
            return;
        }

        var totalWeight = _layoutColumns.Sum(column => GetColumnWeight(column.Key));
        var deltaX = args.ClientX - _resizeStartX;
        var deltaWeight = (deltaX / _resizeGridWidth) * totalWeight;
        var combined = _resizeStartLeftWeight + _resizeStartRightWeight;
        var newLeft = Math.Clamp(_resizeStartLeftWeight + deltaWeight, MinColumnWeight, combined - MinColumnWeight);
        var newRight = combined - newLeft;

        var leftKey = _layoutColumns[_resizeColumnIndex].Key;
        var rightKey = _layoutColumns[_resizeColumnIndex + 1].Key;
        _columnWeights[leftKey] = newLeft;
        _columnWeights[rightKey] = newRight;

        StateHasChanged();
    }

    private void EndColumnResize()
    {
        if (!_isColumnResizing)
        {
            return;
        }

        _isColumnResizing = false;
        _resizeColumnIndex = -1;
        SavePanelState();
    }

    private object? GetFieldValue(FieldMetadata field, SampleData sample)
    {
        var target = field.IsSynthetic ? (object)sample : sample.Payload;
        if (target == null)
        {
            return null;
        }

        // In all-topics mode, skip fields that belong to a different topic type to avoid
        // casting exceptions when the getter is invoked on an incompatible payload.
        if (_fieldTopicTypes.TryGetValue(field, out var expectedTopicType) &&
            expectedTopicType != sample.TopicMetadata.TopicType)
        {
            return null;
        }

        try
        {
            return field.Getter(target);
        }
        catch
        {
            return null;
        }
    }

    private Task HandleViewRebuiltAsync()
    {
        // Replay mode: mark dirty and let the next LoadItems call rebuild from FixedSamples.
        if (FixedSamples != null)
        {
            _viewDirty = true;
            _ = _virtualizeRef?.RefreshDataAsync();
            StateHasChanged();
            return Task.CompletedTask;
        }

        // Live mode: the background SampleView already rebuilt the sorted slice;
        // we just update counts and tell the grid to re-virtualize.
        // Guard against being called after Dispose() nulled _sampleView (InvokeAsync
        // can queue this continuation before the unsubscription completes).
        if (_sampleView == null)
            return Task.CompletedTask;

        var newCount = _sampleView.CurrentFilteredCount;
        _totalCount = newCount;
        _currentCount = newCount;

        if (_trackMode && newCount > 0)
        {
            var latestIndex = _sortDirection == SortDirection.Ascending ? newCount - 1 : 0;
            _selectedIndex = latestIndex;
            var latestSlice = _sampleView.GetVirtualView(latestIndex, 1);
            if (!latestSlice.IsEmpty)
            {
                _selectedSample = latestSlice.Span[0];
                _pendingTrackSample = _selectedSample;
                _trackDebouncer?.Trigger();
            }
        }

        _ = _virtualizeRef?.RefreshDataAsync();
        StateHasChanged();
        return Task.CompletedTask;
    }

    /// <summary>
    /// Rebuilds <see cref="_viewCache"/> from <see cref="FixedSamples"/> applying the active
    /// filter and sort.  Only called in Replay mode.
    /// </summary>
    private void EnsureFixedView()
    {
        if (!_viewDirty)
        {
            return;
        }

        var fixedSamples = FixedSamples!;
        _viewCache.Clear();
        foreach (var sample in fixedSamples)
        {
            if (_filterPredicate == null || _filterPredicate(sample))
            {
                _viewCache.Add(sample);
            }
        }

        ApplySortToViewCache();
        _totalCount = fixedSamples.Count;
        _currentCount = _viewCache.Count;
        _viewDirty = false;
        UpdateSelectionAndTracking();
    }

    private void ApplySortToViewCache()
    {
        if (_sortField == null) return;

        // O(N) fast path for Ordinal/Timestamp: live data arrives in strictly ascending
        // ordinal order so a Reverse() is sufficient for descending, and no-op for ascending.
        // Replay mode (FixedSamples != null) may supply out-of-order samples, so we first
        // validate that the current cache is already monotonically ascending before trusting
        // the fast path. If not, fall through to the general O(N log N) sort.
        if (_sortField.StructuredName == "Ordinal" || _sortField.StructuredName == "Timestamp")
        {
            if (FixedSamples == null || IsCacheAscending(_sortField))
            {
                if (_sortDirection == SortDirection.Descending)
                    _viewCache.Reverse();
                // else: already ascending — nothing to do
                return;
            }
        }

        _viewCache.Sort((left, right) => CompareSamples(left, right, _sortField, _sortDirection));
    }

    /// <summary>
    /// Returns true when <see cref="_viewCache"/> is already sorted in ascending order by
    /// <paramref name="field"/> (i.e. each element compares ≤ the next).
    /// Used to validate the O(N) fast-path assumption before applying <see cref="List{T}.Reverse"/>.
    /// </summary>
    private bool IsCacheAscending(FieldMetadata field)
    {
        for (var i = 1; i < _viewCache.Count; i++)
        {
            if (CompareSamples(_viewCache[i - 1], _viewCache[i], field, SortDirection.Ascending) > 0)
                return false;
        }
        return true;
    }

    /// <summary>
    /// Updates <see cref="_selectedIndex"/> and <see cref="_selectedSample"/> after a view rebuild.
    /// In track mode, auto-selects the latest sample and triggers a debounced detail publish.
    /// Outside track mode, fixes index drift caused by new samples shifting existing rows.
    /// </summary>
    private void UpdateSelectionAndTracking()
    {
        if (_viewCache.Count == 0)
        {
            _selectedSample = null;
            _selectedIndex = -1;
            return;
        }

        if (_trackMode)
        {
            // "Latest" = highest ordinal.
            // Ascending sort: last element; descending sort: first element.
            var latestIndex = _sortDirection == SortDirection.Ascending ? _viewCache.Count - 1 : 0;
            _selectedIndex = latestIndex;
            _selectedSample = _viewCache[latestIndex];
            _pendingTrackSample = _selectedSample;
            _trackDebouncer?.Trigger();
        }
        else if (_selectedSample != null)
        {
            // Fix index drift: the selected sample may have shifted position after rebuildl.
            var newIndex = _viewCache.IndexOf(_selectedSample);
            if (newIndex >= 0)
                _selectedIndex = newIndex;
        }
    }

    private static int CompareSamples(
        SampleData left,
        SampleData right,
        FieldMetadata sortField,
        SortDirection direction)
    {
        var leftValue = GetSortValue(left, sortField);
        var rightValue = GetSortValue(right, sortField);
        var comparison = CompareValues(leftValue, rightValue);
        return direction == SortDirection.Descending ? -comparison : comparison;
    }

    private static object? GetSortValue(SampleData sample, FieldMetadata sortField)
    {
        var target = sortField.IsSynthetic ? sample : sample.Payload;
        return sortField.Getter(target!);
    }

    private static int CompareValues(object? left, object? right)
    {
        if (ReferenceEquals(left, right))
        {
            return 0;
        }

        if (left == null)
        {
            return -1;
        }

        if (right == null)
        {
            return 1;
        }

        if (left is IComparable comparable)
        {
            return comparable.CompareTo(right);
        }

        return string.Compare(left.ToString(), right.ToString(), StringComparison.Ordinal);
    }

    private RenderFragment RenderCellValue(ColumnLayout column, IndexedSample row) => @<text>
        @if (column.Kind == ColumnKind.Ordinal)
        {
            @row.Sample.Ordinal
        }
        else if (column.Kind == ColumnKind.Status)
        {
            <span class="sample-status @GetStatusClass(row.Sample)">@GetStatusSymbol(row.Sample)</span>
        }
        else if (column.Kind == ColumnKind.Field && column.Field != null)
        {
            var value = GetFieldValue(column.Field, row.Sample);
            // ME2-T26: Apply topic color to the synthetic "Topic" field (ShortName).
            var topicColorName = value as string;
            @if (topicColorName != null &&
                 column.Field.IsSynthetic &&
                 string.Equals(column.Field.StructuredName, "Topic", StringComparison.Ordinal) &&
                 !string.IsNullOrEmpty(topicColorName))
            {
                <span class="topic-name-colored" style="@TopicColorService.GetColorStyle(topicColorName)">@topicColorName</span>
            }
            else
            {
                @RenderValue(value)
            }
        }
        else if (column.Kind == ColumnKind.Actions)
        {
            <div class="instances-panel__actions">
                <button type="button" class="instances-panel__action" title="Show detail"
                        @onclick="() => OpenDetail(row.Sample)"
                        @onmouseenter="args => ShowDetailTooltip(row.Sample, args)"
                        @onmouseleave="HideTooltip">D</button>
            </div>
        }
    </text>;

    private RenderFragment RenderValue(object? value) => @<text>
        @if (value == null)
        {
            <span class="samples-panel__value is-null">null</span>
        }
        else if (value is string text)
        {
            <span class="samples-panel__value is-string"
                  @onmouseenter="args => ShowJsonTooltip(text, args)"
                  @onmouseleave="HideTooltip">@text</span>
        }
        else
        {
            <span>@FormatValue(value)</span>
        }
    </text>;

    private void ShowJsonTooltip(string text, MouseEventArgs args)
    {
        if (!JsonTooltipParser.TryFormatJson(text, out var formatted))
        {
            return;
        }

        var html = JsonSyntaxHighlighter.ToHtml(formatted);
        TooltipService.Show(new TooltipState(html, args.ClientX + 12, args.ClientY + 12));
    }

    private async Task ShowDetailTooltip(SampleData sample, MouseEventArgs args)
    {
        try
        {
            var html = await Task.Run(() =>
            {
                var json = JsonSerializer.Serialize(sample.Payload, sample.TopicMetadata.TopicType, TooltipJsonOptions);
                if (json.Length > 3000)
                {
                    json = json.Substring(0, 3000) + "\n... [payload truncated for preview]";
                }
                return JsonSyntaxHighlighter.ToHtml(json);
            });
            TooltipService.Show(new TooltipState(html, args.ClientX + 12, args.ClientY + 12,
                ContextType: sample.TopicMetadata.TopicType,
                ContextValue: sample.Payload));
        }
        catch
        {
            // Ignore tooltip failures for non-serializable payloads.
        }
    }

    private void HideTooltip()
    {
        TooltipService.Hide();
    }

    private string GetStatusClass(SampleData sample)
    {
        return sample.SampleInfo.InstanceState switch
        {
            DdsInstanceState.Alive => "sample-status--alive",
            DdsInstanceState.NotAliveDisposed => "sample-status--disposed",
            _ => "sample-status--no-writers"
        };
    }

    private string GetStatusSymbol(SampleData sample)
    {
        return sample.SampleInfo.InstanceState switch
        {
            DdsInstanceState.Alive => "o",
            DdsInstanceState.NotAliveDisposed => "!",
            _ => "x"
        };
    }

    private static string GetStatusTooltip(SampleData sample)
    {
        return sample.SampleInfo.InstanceState switch
        {
