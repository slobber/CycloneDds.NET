    public void Dispose()
    {
        SampleStore.Cleared -= OnSampleStoreCleared;
        _addColumnSubscription?.Dispose();
        _applyFilterSubscription?.Dispose();

        // Unhook and dispose the background SampleView first to stop new OnViewRebuilt events
        // from being queued via InvokeAsync.  Running on the Blazor synchronization context means
        // any already-queued HandleViewRebuiltAsync continuations will execute after this method
        // returns, so we must null _sampleView and _trackDebouncer so those continuations
        // short-circuit via the ?. null-checks rather than calling into disposed objects.
        if (_sampleView != null)
        {
            if (_viewRebuiltHandler != null)
            {
                _sampleView.OnViewRebuilt -= _viewRebuiltHandler;
            }

            _sampleView.Dispose();
            _sampleView = null;
        }

        _trackDebouncer?.Dispose();
        _trackDebouncer = null;
    }

    /// <summary>
    /// Called synchronously when <see cref="ISampleStore.Cleared"/> fires so all
    /// SampleData references held by this panel are dropped before the GC runs.
    /// </summary>
    private void OnSampleStoreCleared()
    {
        _selectedSample = null;
        _pendingTrackSample = null;
        _selectedIndex = -1;
        _viewCache.Clear();
    }
